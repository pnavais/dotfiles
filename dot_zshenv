# Globals
# -------
export EDITOR=nvim
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# Bootstrap PATH enough to find mise when launched from GUI / Finder
export PATH="/run/current-system/sw/bin:/opt/homebrew/bin:/usr/local/bin:${HOME}/.local/bin:${PATH}"

# Activate mise in Cursor agent or non-interactive shells
if [[ -n "$CURSOR_AGENT" ]] || [[ $- != *i* ]]; then
  eval "$(mise activate zsh)"
fi
