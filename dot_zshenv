# Globals
# -------
export EDITOR=nvim
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export LC_CTYPE=en_US.UTF-8

# Override omlx in the path with the custom launcher
if [[ -x /usr/local/bin/omlx ]]; then
  omlx() { /usr/local/bin/omlx "$@"; }
fi

if [[ -n "$CURSOR_AGENT" ]] || [[ $- != *i* ]]; then
	# Bootstrap PATH enough to find mise when launched from GUI / Finder
	if ! command -v mise &>/dev/null; then
		export PATH="/run/current-system/sw/bin:/opt/homebrew/bin:/usr/local/bin:${HOME}/.local/bin:${PATH}"
	fi

	# Activate mise in Cursor agent or non-interactive shells
	eval "$(mise activate zsh)"
fi
