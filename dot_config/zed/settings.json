// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    },
    "cursor": {
      "type": "registry"
    }
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent": {
    "tool_permissions": {
      "default": "allow"
    },
    "dock": "right",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1"
    },
  },
  "vim_mode": true,
  "ensure_final_newline_on_save": false,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "lsp": {
    "nil": {
      "initialization_options": {
        "formatting": {
          "command": ["nixfmt"]
        }
      },
      "binary": {
        "path": "nil"
      },
      "settings": {
        "diagnostics": {
          "enabled": true
        }
      }
    },
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "features": ["fetcher"],
          "allTargets": true
        },
        "check": {
          "workspace": true
        }
      }
    }
  },
  "languages": {
    "Nix": {
      "formatter": "language_server",
      "enable_language_server": true,
      "language_servers": ["nil", "..."],
      "format_on_save": "on"
    }
  }
}
